# ==========================================
# DEPENDENCIAS Y COMPILACIÓN
# ==========================================
node_modules/
dist/
build/
.npm/

# ==========================================
# VARIABLES DE ENTORNO (¡SEGURIDAD CRUCIAL!)
# ==========================================
# Bloquea credenciales de Postgres, MinIO, etc.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# PRUEBAS Y ARCHIVOS MULTIMEDIA LOCALES
# ==========================================
# Ignora las descargas generadas por los tests
src/test/descargas/*
!src/test/descargas/.gitkeep

# Ignora los archivos multimedia pesados (imágenes/videos de prueba)
src/test/assets/*
!src/test/assets/.gitkeep

# ==========================================
# INFRAESTRUCTURA Y CONTENEDORES (OPCIONAL)
# ==========================================
# Si usas volúmenes de Docker persistentes en carpetas locales, ignóralos aquí:
# .docker-data/
# pg-data/

# ==========================================
# LOGS Y SISTEMA OPERATIVO
# ==========================================
# Logs de Node/NPM
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Archivos del sistema
.DS_Store
Thumbs.db
.jsorg/

# Configuraciones de editores (Opcional)
.vscode/
.idea/

# ==========================================
# MONOREPO / GENERAL
# ==========================================
# Ignora node_modules y builds en cualquier subcarpeta (client/server)
**/node_modules/
**/dist/
**/build/

# TypeScript build cache
*.tsbuildinfo

# Cachés y artefactos
.cache/
.parcel-cache/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Entornos/credenciales (NO subir)
.env
.env.*

# ts-node / ts-node-dev artifacts
.ts-node/
ts-node-dev.log

# Test artifacts and local media used only for testing
src/test/descargas/*
!src/test/descargas/.gitkeep
src/test/assets/*
!src/test/assets/.gitkeep

# Optional: Docker / DB volumes uncomment if used locally
# .docker-data/
# pg-data/

# ==========================================
# GO SYNC
# ==========================================
go-sync/sync-server.exe
go-sync/sync-client.exe
go-sync/scripts/bin/
go-sync/go.sum